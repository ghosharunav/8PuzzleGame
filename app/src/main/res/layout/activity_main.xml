<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D1B2A">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/headerBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1A2E45"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvModeLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="MODE 1"
            android:textColor="#5B8DB8"
            android:textSize="12sp"
            android:letterSpacing="0.3"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="8 PUZZLE"
            android:textColor="#E0F0FF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_weight="0"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="end"
            android:id="@+id/tvModeDesc"
            android:text="Classic"
            android:textColor="#5B8DB8"
            android:textSize="12sp"/>
    </LinearLayout>

    <!-- Stats Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MOVES"
                android:textColor="#5B8DB8"
                android:textSize="10sp"
                android:letterSpacing="0.2"/>
            <TextView
                android:id="@+id/tvMoves"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#E0F0FF"
                android:textSize="28sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TIME"
                android:textColor="#5B8DB8"
                android:textSize="10sp"
                android:letterSpacing="0.2"/>
            <TextView
                android:id="@+id/tvTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textColor="#E0F0FF"
                android:textSize="28sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OPT. LEFT"
                android:textColor="#5B8DB8"
                android:textSize="10sp"
                android:letterSpacing="0.2"/>
            <TextView
                android:id="@+id/tvOptimal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="#F4A261"
                android:textSize="28sp"
                android:textStyle="bold"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Goal State Preview -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingBottom="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GOAL → "
            android:textColor="#5B8DB8"
            android:textSize="12sp"/>

        <TextView
            android:id="@+id/tvGoalPreview"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1 2 3 | 4 5 6 | 7 8 _"
            android:textColor="#E0F0FF"
            android:textSize="12sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- Puzzle Grid -->
    <GridLayout
        android:id="@+id/puzzleGrid"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_margin="16dp"
        android:columnCount="3"
        android:rowCount="3"
        android:useDefaultMargins="false"/>

    <!-- Status Message -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:text="Press START to begin!"
        android:textSize="14sp"
        android:textStyle="italic"
        android:textColor="#5B8DB8"
        android:layout_marginBottom="4dp"
        android:layout_marginTop="4dp"/>

    <!-- Buttons Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center">

        <Button
            android:id="@+id/btnStart"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="START"
            android:backgroundTint="#2E7D32"
            android:textColor="#FFFFFF"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:layout_marginEnd="12dp"/>

        <Button
            android:id="@+id/btnNewGame"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NEW GAME"
            android:backgroundTint="#1A2E45"
            android:textColor="#E0F0FF"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:layout_marginEnd="12dp"/>

        <Button
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MODES"
            android:backgroundTint="#2A1F3D"
            android:textColor="#E0F0FF"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"/>
    </LinearLayout>

    <!-- Win Message -->
    <TextView
        android:id="@+id/tvWinMessage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="🎉 Puzzle Solved!"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#4CAF50"
        android:visibility="gone"
        android:layout_marginBottom="8dp"/>

</LinearLayout>